{
  "name": "courtsync-backend",
  "version": "1.0.0",
  "description": "CourtSync Backend API - Court booking system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --files src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed:users": "ts-node --files src/seeders/users.seed.ts",
    "seed:courts": "ts-node --files src/seeders/courts.seed.ts",
    "seed:bookings": "ts-node --files src/seeders/bookings.seed.ts",
    "seed:all": "npm run seed:users && npm run seed:courts && npm run seed:bookings",
    "test": "jest"
  },
  "keywords": [
    "court",
    "booking",
    "api",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.3",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
